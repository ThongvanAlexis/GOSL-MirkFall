          "sql": "CREATE TABLE IF NOT EXISTS \"t_sessions\" (\"id\" TEXT NOT NULL, \"display_name\" TEXT NOT NULL, \"status\" TEXT NOT NULL CHECK(\"status\" IN ('active', 'stopped')), \"started_at_utc\" INTEGER NOT NULL, \"started_at_offset_minutes\" INTEGER NOT NULL CHECK(\"started_at_offset_minutes\" BETWEEN -720 AND 840), \"stopped_at_utc\" INTEGER NULL, \"stopped_at_offset_minutes\" INTEGER NULL CHECK(\"stopped_at_offset_minutes\" BETWEEN -720 AND 840), \"notes\" TEXT NULL, \"mirk_style_id\" TEXT NULL REFERENCES t_mirk_styles (id) ON DELETE SET NULL, PRIMARY KEY (\"id\"));"
        }
      ]
